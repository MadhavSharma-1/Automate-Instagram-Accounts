# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/iga?schema=public"

# --- Anthropic (caption generation) ---
ANTHROPIC_API_KEY="sk-ant-..."
# Default model for caption generation
ANTHROPIC_MODEL="claude-opus-4-8"

# --- Instagram Graph API (per-account tokens are stored in the DB; these are app-level) ---
# Create a Meta app, add Instagram Graph API, get a long-lived token per IG Business/Creator account.
META_APP_ID=""
META_APP_SECRET=""

# --- Affiliate / product source APIs ---
# Amazon Product Advertising API (PA-API 5.0) — requires an Associates account
AMAZON_PAAPI_ACCESS_KEY=""
AMAZON_PAAPI_SECRET_KEY=""
AMAZON_PARTNER_TAG=""
# Marketplace must match where you signed up. Examples:
#   IN: host=webservices.amazon.in     region=eu-west-1
#   US: host=webservices.amazon.com    region=us-east-1
#   UK: host=webservices.amazon.co.uk  region=eu-west-1
#   DE: host=webservices.amazon.de     region=eu-west-1
AMAZON_PAAPI_HOST="webservices.amazon.in"
AMAZON_PAAPI_REGION="eu-west-1"

# AliExpress Affiliate / Open Platform
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
ALIEXPRESS_TRACKING_ID=""

# Temu affiliate (program credentials)
TEMU_AFFILIATE_KEY=""

# --- Video generation provider (pluggable) ---
# Which provider the video pipeline uses. Options: "stub" | "shotstack" | "replicate"
VIDEO_PROVIDER="stub"
# Shotstack: use "stage" for the free sandbox (watermarked), "v1" for production.
SHOTSTACK_API_KEY=""
SHOTSTACK_ENV="stage"
# Optional: public mp3 URL used as background music in rendered videos.
SHOTSTACK_MUSIC_URL=""
REPLICATE_API_TOKEN=""

# --- Object storage for rendered videos (S3-compatible) ---
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_BASE_URL=""

# --- Admin auth (simple shared secret for the MVP; replace with real auth before production) ---
ADMIN_PASSWORD="change-me"
